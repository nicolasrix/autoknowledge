# Copy this file to .env and fill in your values.
# docker compose reads .env automatically.

# ── Vault location ────────────────────────────────────────────────────────────
# Choose ONE of the two options below.

# Option A: Local path on the host (comment out if using SMB)
# VAULT_PATH=/home/yourname/obsidian-vault

# Option B: SMB/CIFS share (TrueNAS, Samba, etc.)
# Format: HOST/SHARE/path/to/vault  (no leading smb:// or //)
SMB_HOST=truenas.local
SMB_USER=smbshare
# SMB_PASSWORD=
SMB_SHARE_PATH=Vault/Media/obsidian/truenas-obsidian-vault

# ── Embedding model ───────────────────────────────────────────────────────────
# Model pulled and served by Ollama. Must match embedding.model and
# embedding.dimension in config.toml (or AUTOKNOWLEDGE_EMBEDDING_MODEL env var).
#
# Model options (Ollama):        dimension
#   nomic-embed-text (default)     768      good quality, ~274 MB
#   mxbai-embed-large             1024      best quality,  ~670 MB
#   all-minilm                     384      fastest,        ~46 MB
#
# EMBEDDING_MODEL=nomic-embed-text
# EMBEDDING_DIMENSION=768

# ── Host port ─────────────────────────────────────────────────────────────────
# Change if 8080 is already in use on your host.
# AUTOKNOWLEDGE_PORT=8080
