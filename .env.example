# Copy this file to .env and fill in your values.
# docker compose reads .env automatically.

# Absolute path to your Obsidian vault on the host.
VAULT_PATH=/home/yourname/obsidian-vault

# Embedding model served by OpenLLM (must match config.toml embedding.model).
# OPENLLM_MODEL=BAAI/bge-small-en-v1.5
